{:tasks
 {:enter (println "Running task:" (:name (current-task)))

  fmt-check {:doc "Check code formatting"
             :task (shell "cargo fmt --all -- --check")}

  fmt {:doc "Fix code formatting"
       :task (shell "cargo fmt --all")}

  lint {:doc "Lint code"
        :task (shell "cargo clippy --all-targets -- -D warnings")}

  test {:doc "Run tests"
        :task (shell "cargo test")}

  e2e {:doc "End-to-end tests (spawns real binary, speaks LSP over stdio)"
       :task (shell "cargo test --test test_e2e")}

  e2e-real {:doc "E2E against a real Maven classpath (needs clojure CLI + network)"
            :task (shell "cargo test --test test_e2e -- --ignored")}

  e2e-nvim {:doc "Real-editor-client e2e via headless Neovim"
            :task (do (shell "cargo build")
                      (shell "nvim --headless -l scripts/e2e_nvim.lua tests/fixtures/simple_project target/debug/clj-lsp"))}

  check {:doc "Run all code checks and tests"
         :depends [fmt lint test]}

  outdated {:doc "Check for outdated dependencies"
            :task (shell "cargo outdated")}

  build {:doc "Build application binary"
         :task (shell "cargo build")}
  
  release {:doc "Build application release binary"
           :task (shell "cargo build --release")}}}
